{
  "name": "Mystical Timeline Dev",
  "dockerComposeFile": [
    "docker-compose.yml"
  ],
  "service": "mystical-timeline-dev",
  "workspaceFolder": "/mystical-timeline",
  "postCreateCommand": "./.devcontainer/auth.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "Angular.ng-template",
        "ms-vscode.vscode-typescript-next",
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "ms-azuretools.vscode-docker",
        "naumovs.color-highlight",
        "manishsencha.readme-preview",
        "wix.vscode-import-cost",
        "esbenp.prettier-vscode",
        "mohd-akram.vscode-html-format",
        "magson.dark-hacker-theme"
      ]
    }
  }
}